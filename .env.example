# FirstPass — copy to .env.local and fill in. Every integration falls back to
# deterministic cached/mock data when its key is absent, so the app runs and
# demos without any of these. Add keys to make each integration go LIVE.

# Anthropic / Claude — rule interpretation, plan extraction, report writing
ANTHROPIC_API_KEY=

# Browserbase — live navigation of official Alameda permitting sites
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Redis — shared agent memory, rule/finding/source stores (Upstash works on Vercel)
# Standard redis:// or rediss:// URL. Leave blank to use in-memory store.
REDIS_URL=

# Arize — tracing + evaluation (citation / authority / applicability / hallucination)
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Band — multi-agent message bus / activity feed. The local feed always works.
# Set BAND_API_KEY (an orchestrator agent key, band_a_...) to make a run open a
# REAL Band room: it validates /me, creates a chat, adds you (the human owner)
# and the three registered research agents, and posts a kickoff @mention.
# Register these External Agents at app.band.ai with these exact names; their
# ids default to the ones the room was first built with (override if you re-register):
#   - Municipal Code Researcher  (BAND_AGENT_MUNICIPAL_ID)
#   - State Code Researcher       (BAND_AGENT_STATE_ID)
#   - Code Synthesizer            (BAND_AGENT_SYNTHESIZER_ID)
BAND_API_KEY=
BAND_AGENT_MUNICIPAL_ID=
BAND_AGENT_STATE_ID=
BAND_AGENT_SYNTHESIZER_ID=
# Optional: override the Band REST endpoint for self-hosted deployments.
BAND_REST_URL=https://app.band.ai/api/v1/agent
# Legacy single-room forward fallback (used only if no room is created above).
BAND_CHAT_ID=
BAND_MENTION_ID=
BAND_MENTION_NAME=
BAND_MENTION_HANDLE=

# Autodesk Platform Services (APS) — DWG upload + Model Derivative translation.
# 2-legged (client credentials); the callback is only needed for 3-legged flows.
APS_CLIENT_ID=
APS_CLIENT_SECRET=
APS_CALLBACK_URL=http://localhost:3000/api/aps/auth
